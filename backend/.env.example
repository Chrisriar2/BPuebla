# BASTA PUEBLA — backend. Copia a .env para correr en LOCAL (sin Docker).
# En Docker local estas variables las define docker-compose.yml (host = db).
# En Render se definen en el dashboard / render.yaml (NUNCA subas un .env real).

# Puerto HTTP de la API (Render lo inyecta automáticamente)
PORT=3000

# --- Conexión a PostgreSQL/PostGIS ---
# Opción A (Render y local moderno): cadena única.
# En Render: pégala desde tu base de datos (Internal Database URL).
# DATABASE_URL=postgresql://usuario:password@host:5432/basta_puebla
# Si tu Postgres LOCAL no tiene SSL y usas DATABASE_URL, descomenta:
# PGSSL=disable

# Opción B (local clásico): variables sueltas (se ignoran si hay DATABASE_URL).
PGHOST=localhost
PGPORT=5432
PGUSER=basta
PGPASSWORD=basta
PGDATABASE=basta_puebla

# Tamaño máximo del pool de conexiones
PG_POOL_MAX=10

# --- Seguridad ---
# Secreto para firmar los JWT (HS256). En Render: genera un valor aleatorio largo.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Orígenes permitidos para CORS, separados por comas. "*" = cualquiera (solo demo/local).
# En producción: la URL de tu frontend en Vercel. Los orígenes del APK del chofer
# (http(s)://localhost, capacitor://localhost) se permiten SIEMPRE, no los agregues.
CORS_ORIGIN=*
# CORS_ORIGIN=https://basta-puebla.vercel.app

# PIN comodín para el login demo de choferes sin usuario sembrado
CHOFER_DEMO_PIN=1234
